<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panduan Fitur Earn & Referral — Halodoc Doctors</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal: #1a8c73;
    --teal-light: #f0faf6;
    --teal-border: #9FE1CB;
    --teal-dark: #0f6e56;
    --teal-deeper: #085041;
    --danger: #e24b4a;
    --danger-light: #fef3f2;
    --amber: #BA7517;
    --amber-light: #fff8e1;
    --amber-border: #FAC775;
    --text: #1a1a1a;
    --text-2: #555;
    --text-3: #888;
    --border: rgba(0,0,0,0.09);
    --bg: #f7f8f6;
    --white: #ffffff;
    --radius: 12px;
    --radius-sm: 7px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ─── HERO ─── */
  .hero {
    background: var(--teal);
    padding: 64px 24px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(255,255,255,0.07) 0%, transparent 70%);
  }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.2);
    margin-bottom: 20px;
  }
  .hero h1 {
    font-size: clamp(22px, 4vw, 36px);
    font-weight: 600;
    color: #fff;
    max-width: 680px;
    margin: 0 auto 14px;
    line-height: 1.3;
  }
  .hero p {
    font-size: 16px;
    color: rgba(255,255,255,0.75);
    max-width: 480px;
    margin: 0 auto;
  }

  /* ─── NAV DOTS ─── */
  .nav-strip {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 12px rgba(0,0,0,0.05);
  }
  .nav-strip::-webkit-scrollbar { display: none; }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-3);
    white-space: nowrap;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
  }
  .nav-item:hover { color: var(--teal); }
  .nav-item.active { color: var(--teal); border-bottom-color: var(--teal); }
  .nav-num {
    width: 20px; height: 20px;
    background: var(--teal-light);
    color: var(--teal);
    border-radius: 50%;
    font-size: 11px;
    font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  /* ─── SECTIONS ─── */
  .section {
    padding: 64px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-header {
    margin-bottom: 40px;
  }
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 10px;
  }
  .section-label::before {
    content: '';
    width: 20px; height: 2px;
    background: var(--teal);
    border-radius: 2px;
  }
  .section-title {
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .section-desc {
    font-size: 15px;
    color: var(--text-2);
    max-width: 600px;
  }
  .divider {
    height: 1px;
    background: var(--border);
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ─── STEP GRIDS ─── */
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; max-width: 740px; }
  .grid-2-full { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; }
  @media (max-width: 900px) {
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .grid-3, .grid-2, .grid-2-full { grid-template-columns: 1fr; }
  }

  /* ─── STEP CARD ─── */
  .card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .card:hover {
    box-shadow: 0 8px 32px rgba(26,140,115,0.12);
    transform: translateY(-2px);
  }
  .card-header {
    background: var(--teal);
    padding: 11px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .card-badge {
    background: rgba(255,255,255,0.22);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    border-radius: 5px;
    padding: 2px 8px;
    white-space: nowrap;
    font-family: 'DM Mono', monospace;
  }
  .card-header-title { color: #fff; font-size: 12px; font-weight: 500; }

  /* ─── PHONE MOCKUP ─── */
  .phone { background: #f3f4f6; margin: 14px 14px 0; border-radius: 10px; border: 1px solid var(--border); overflow: hidden; }
  .topbar-teal { background: var(--teal); padding: 8px 11px; display: flex; align-items: center; gap: 6px; }
  .topbar-white { background: #fff; border-bottom: 1px solid var(--border); padding: 8px 11px; display: flex; align-items: center; gap: 6px; }
  .tb-back-w { color: #fff; font-size: 13px; }
  .tb-back { color: var(--text); font-size: 13px; }
  .tb-title-w { font-size: 11px; font-weight: 500; color: #fff; flex: 1; }
  .tb-title { font-size: 11px; font-weight: 500; color: var(--text); flex: 1; }
  .pb { padding: 10px; background: #f3f4f6; }
  .pb-w { padding: 10px; background: #fff; }

  /* phone internals */
  .earn-banner { background: var(--teal); border-radius: 8px; padding: 10px 12px; margin-bottom: 8px; }
  .earn-lbl { font-size: 9px; color: rgba(255,255,255,0.8); }
  .earn-val { font-size: 19px; font-weight: 600; color: #fff; }
  .stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-bottom: 5px; }
  .stat-box { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 6px 8px; }
  .s-lbl { font-size: 8px; color: var(--text-3); }
  .s-num { font-size: 14px; font-weight: 600; color: var(--text); }
  .sec-lbl { font-size: 10px; font-weight: 600; color: var(--text); margin: 8px 0 5px; }
  .ref-card-p { background: #fff; border: 1px solid var(--border); border-radius: 7px; padding: 8px 9px; margin-bottom: 5px; }
  .ref-card-p.hl { border: 1.5px solid var(--teal); }
  .ref-row { display: flex; justify-content: space-between; align-items: flex-start; }
  .ref-name-p { font-size: 10px; font-weight: 600; color: var(--text); line-height: 1.3; }
  .badge-a { background: var(--teal-light); border: 1px solid var(--teal-border); border-radius: 4px; padding: 1px 6px; font-size: 8px; color: var(--teal-dark); font-weight: 600; white-space: nowrap; }
  .badge-d { background: var(--danger-light); border: 1px solid #F09595; border-radius: 4px; padding: 1px 6px; font-size: 8px; color: #791F1F; font-weight: 600; white-space: nowrap; }
  .ref-cat { font-size: 8px; color: var(--text-3); margin: 1px 0; }
  .ref-meds-p { font-size: 8px; color: var(--text-3); margin-bottom: 5px; }
  .rs-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 3px; margin-bottom: 5px; }
  .rs-lbl { font-size: 7px; color: var(--text-3); }
  .rs-val { font-size: 11px; font-weight: 600; color: var(--text); }
  .earn-chip { background: var(--teal-light); border-radius: 4px; padding: 3px 7px; font-size: 8px; color: var(--teal-dark); margin-bottom: 6px; }
  .earn-chip-sm { background: var(--teal-light); border: 1px solid var(--teal-border); border-radius: 3px; display: inline-block; padding: 1px 5px; font-size: 8px; color: var(--teal-dark); margin-top: 2px; }
  .cbtns { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
  .btn-ol { border: 1px solid var(--teal); color: var(--teal); background: #fff; border-radius: 5px; text-align: center; padding: 4px; font-size: 8px; font-weight: 500; }
  .btn-ol.glow { border-width: 1.5px; box-shadow: 0 0 0 3px rgba(26,140,115,0.12); }
  .btn-tl { background: var(--teal); color: #fff; border-radius: 5px; text-align: center; padding: 4px; font-size: 8px; font-weight: 500; }
  .btn-tl.glow { box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--teal); }
  .btn-tl-full { background: var(--teal); color: #fff; border-radius: 7px; text-align: center; padding: 8px; font-size: 10px; font-weight: 600; margin-top: 6px; }
  .btn-tl-full.glow { box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--teal); }
  .btn-dl { border: 1px solid var(--danger); color: var(--danger); background: #fff; border-radius: 5px; text-align: center; padding: 5px; font-size: 8px; font-weight: 500; }
  .btn-dl.glow { border-width: 1.5px; box-shadow: 0 0 0 3px rgba(226,75,74,0.1); }
  .btn-react { background: var(--teal); color: #fff; border-radius: 5px; text-align: center; padding: 5px; font-size: 8px; font-weight: 500; }
  .btn-react.glow { box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--teal); }
  .btn-no { border: 1px solid var(--border); color: var(--text-3); background: #fff; border-radius: 5px; text-align: center; padding: 5px; font-size: 8px; font-weight: 500; }
  .warn-box { background: var(--amber-light); border: 1px solid var(--amber-border); border-radius: 6px; padding: 5px 7px; margin-bottom: 7px; display: flex; gap: 5px; }
  .wi { color: var(--amber); font-size: 10px; flex-shrink: 0; }
  .wt { font-size: 8px; color: #5a3a00; line-height: 1.4; }
  .med-row-p { padding: 5px 0; border-bottom: 1px solid var(--border); }
  .med-row-p:last-child { border-bottom: none; }
  .med-name-p { font-size: 9px; font-weight: 600; color: var(--text); }
  .med-meta-p { font-size: 8px; color: var(--text-3); line-height: 1.3; }
  .add-med { display: flex; align-items: center; justify-content: center; gap: 3px; border: 1px solid var(--border); border-radius: 5px; padding: 5px; font-size: 8px; color: var(--teal); font-weight: 500; margin: 6px 0; }
  .earn-footer { background: var(--teal-light); border-radius: 4px; padding: 4px 7px; font-size: 8px; color: var(--teal-dark); margin-top: 4px; }
  .empty-state { background: #fff; border-radius: 8px; padding: 10px; margin-top: 4px; }
  .empty-title { font-size: 10px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
  .empty-desc { font-size: 8px; color: var(--text-3); line-height: 1.5; }
  .link-row-p { background: #f3f4f6; border-radius: 5px; padding: 5px 7px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; }
  .link-text-p { font-size: 8px; color: var(--text-3); font-family: 'DM Mono', monospace; }
  .det-card { border: 1px solid var(--teal); border-radius: 7px; padding: 7px 8px; margin-bottom: 6px; }
  .det-card.del { border-color: var(--danger); }
  .tab-row { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--border); }
  .tab { text-align: center; padding: 7px 0; font-size: 9px; color: var(--text-3); }
  .tab.on { color: var(--teal); font-weight: 600; border-bottom: 2px solid var(--teal); }
  .search-bar-p { display: flex; align-items: center; gap: 4px; background: #f3f4f6; border-radius: 5px; padding: 4px 7px; margin: 6px 0; }
  .sb-txt { font-size: 8px; color: var(--text-3); flex: 1; }
  .form-lbl { font-size: 9px; font-weight: 500; color: var(--text); margin-bottom: 3px; display: block; }
  .req { color: var(--danger); }
  .form-inp { width: 100%; box-sizing: border-box; border: 1.5px solid var(--teal); border-radius: 6px; padding: 6px 8px; font-size: 9px; color: var(--text); background: #fff; margin-bottom: 10px; }
  .form-inp-empty { width: 100%; box-sizing: border-box; border: 1px solid var(--border); border-radius: 6px; padding: 6px 8px; font-size: 9px; color: var(--text-3); background: #fff; margin-bottom: 10px; }
  .form-sel { width: 100%; box-sizing: border-box; border: 1px solid var(--border); border-radius: 6px; padding: 6px 8px; font-size: 9px; color: var(--text); background: #fff; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
  .feat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }
  .feat-tile { background: #fff; border: 1px solid var(--border); border-radius: 7px; padding: 8px 8px 9px; }
  .feat-tile.hl { border: 1.5px solid var(--teal); background: var(--teal-light); }
  .feat-icon { font-size: 15px; margin-bottom: 3px; }
  .feat-label { font-size: 9px; color: var(--text); font-weight: 500; line-height: 1.3; }
  .feat-tile.hl .feat-label { color: var(--teal-dark); }
  .qty-row { display: flex; align-items: center; gap: 5px; margin-bottom: 6px; }
  .qty-btn { width: 17px; height: 17px; border: 1px solid var(--border); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--teal); flex-shrink: 0; line-height: 1; }
  .qty-v { font-size: 11px; font-weight: 600; color: var(--text); min-width: 12px; text-align: center; }
  .qty-u { font-size: 9px; color: var(--text-3); }
  .cb-row { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 5px; }
  .cb-item { display: flex; align-items: center; gap: 3px; font-size: 8px; color: var(--text-3); }
  .cb { width: 10px; height: 10px; border: 1px solid var(--border); border-radius: 2px; flex-shrink: 0; }
  .cb.on { background: var(--teal); border-color: var(--teal); }
  .notes-box { background: #f8f8f8; border: 1px solid var(--border); border-radius: 5px; padding: 5px 6px; font-size: 8px; color: var(--text-3); line-height: 1.4; margin-bottom: 7px; }
  .med-img-p { width: 28px; height: 28px; background: #e8f5e9; border-radius: 5px; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
  .add-btn-p { background: var(--teal); color: #fff; font-size: 8px; font-weight: 600; border-radius: 5px; padding: 4px 8px; white-space: nowrap; }
  .pkg-title-p { font-size: 10px; font-weight: 600; color: var(--text); }
  .pkg-date { font-size: 8px; color: var(--text-3); margin-bottom: 5px; }
  .med-icons { display: flex; gap: 4px; font-size: 10px; color: var(--text-3); }
  .contacts-row { display: flex; gap: 8px; overflow: hidden; margin-bottom: 8px; }
  .contact { display: flex; flex-direction: column; align-items: center; gap: 3px; }
  .contact-av { width: 28px; height: 28px; border-radius: 50%; background: #c8f0e4; border: 1.5px solid var(--teal); display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 600; color: var(--teal-dark); position: relative; }
  .wa-b { position: absolute; bottom: -2px; right: -2px; width: 9px; height: 9px; background: #25d366; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 6px; color: #fff; font-weight: 700; }
  .contact-name { font-size: 7px; color: var(--text-3); text-align: center; max-width: 32px; line-height: 1.2; }
  .app-icons-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; margin-bottom: 6px; }
  .app-icon { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .app-icon-circle { width: 28px; height: 28px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 14px; }
  .app-icon-label { font-size: 7px; color: var(--text-3); }
  .share-row-item { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-top: 1px solid var(--border); font-size: 9px; color: var(--text); }
  .no-share-note { background: var(--danger-light); border: 1px solid #F09595; border-radius: 5px; padding: 5px 8px; font-size: 8px; color: #791F1F; line-height: 1.4; margin: 6px 10px 10px; }
  .success-icon { width: 34px; height: 34px; background: #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 7px; font-size: 16px; color: #fff; font-weight: 700; }
  .popup-overlay { background: #fff; border-radius: 10px 10px 0 0; border-top: 1px solid var(--border); padding: 12px 11px 10px; }
  .popup-title { font-size: 11px; font-weight: 600; color: var(--text); text-align: center; margin-bottom: 3px; }
  .popup-desc { font-size: 8px; color: var(--text-3); text-align: center; line-height: 1.4; margin-bottom: 7px; }
  .popup-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }
  .screen-dimmed .screen-bg { opacity: 0.3; }
  .drop-m { border: 1px solid var(--border); border-radius: 4px; padding: 3px 6px; font-size: 8px; color: var(--text); display: inline-flex; align-items: center; gap: 3px; }

  /* ─── ANNOTATION ─── */
  .annotation { padding: 13px 16px 15px; }
  .anno { font-size: 13px; color: var(--text-2); line-height: 1.6; }
  .anno strong { color: var(--text); font-weight: 600; }
  .bullet-list { margin: 6px 0 0; padding: 0; list-style: none; }
  .bullet-list li { font-size: 13px; color: var(--text-2); padding: 2px 0 2px 16px; position: relative; line-height: 1.6; }
  .bullet-list li::before { content: "•"; position: absolute; left: 0; color: var(--teal); }
  .bullet-list li strong { color: var(--text); font-weight: 600; }
  .bullet-list li.no::before { content: "✕"; color: var(--danger); font-size: 9px; top: 4px; }
  .callout { background: var(--teal-light); border: 1px solid var(--teal-border); border-radius: 7px; padding: 7px 10px; margin-top: 8px; font-size: 12px; color: var(--teal-dark); line-height: 1.5; }
  .callout strong { color: var(--teal-deeper); }

  /* ─── FOOTER ─── */
  footer {
    background: var(--teal);
    color: rgba(255,255,255,0.7);
    text-align: center;
    padding: 32px 24px;
    font-size: 13px;
    margin-top: 40px;
  }
  footer strong { color: #fff; }

  /* ─── SECTION SEPARATOR ─── */
  .section-sep {
    display: flex;
    align-items: center;
    gap: 16px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section-sep::before, .section-sep::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }
  .section-sep span {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    white-space: nowrap;
  }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-badge">Halodoc Doctors · Panduan Fitur</div>
  <h1>Panduan Lengkap Earn (Affiliate & Referral)</h1>
  <p>Pelajari cara membuat, mengelola, dan membagikan paket referral obat untuk pasien Anda</p>
</div>

<!-- NAV -->
<nav class="nav-strip">
  <a class="nav-item active" href="#section1"><span class="nav-num">1</span>Membuat Referral</a>
