<!-- ════════════════════════════════════════════════
     SECTION 1 — MEMBUAT REFERRAL (12 langkah)
════════════════════════════════════════════════ -->
<div id="section1">

  <!-- 1A: Langkah 1–3 -->
  <section class="section">
    <div class="section-header">
      <div class="section-label">Bagian 1</div>
      <h2 class="section-title">Bagaimana cara dokter masuk ke halaman referral & membuat referral?</h2>
      <p class="section-desc">Ikuti langkah berikut untuk mengakses fitur Earn dan mulai membuat paket referral obat.</p>
    </div>
    <div class="grid-3">

      <!-- L1 -->
      <div class="card">
        <div class="card-header"><span class="card-badge">Langkah 1</span><span class="card-header-title">Masuk ke fitur Earn</span></div>
        <div class="phone">
          <div class="topbar-teal"><span class="tb-back-w">←</span><span class="tb-title-w" style="text-align:center;">Halodoc Doctors</span><span style="font-size:12px;color:rgba(255,255,255,0.7);">⚙</span></div>
          <div class="pb">
